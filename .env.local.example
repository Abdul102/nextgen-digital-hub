# Copy this file to .env.local and fill in real values.
# In Vercel, add the same vars under Settings -> Environment Variables.

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com (free M0 cluster)
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/nextgen?retryWrites=true&w=majority

# NextAuth
# NEXTAUTH_SECRET: any random 32+ char string. Generate via: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-long-random-string
# NEXTAUTH_URL: your production URL on Vercel; leave http://localhost:3000 for dev
NEXTAUTH_URL=http://localhost:3000

# Single-admin credentials (used to log into /admin)
ADMIN_EMAIL=admin@nextgendigitalhub.com
ADMIN_PASSWORD=ChangeMe!2026

# Anthropic Claude API (chatbot)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Pusher (real-time notifications)
# Get from: https://dashboard.pusher.com (free tier: 200k messages/day)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=us2
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=us2
