# Copy this file to .env.local and fill in real values.
# In Vercel, add the same vars under Settings -> Environment Variables.

# ==== Required ====
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/nextgen?retryWrites=true&w=majority
NEXTAUTH_SECRET=replace-with-long-random-string
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@nextgendigitalhub.com
ADMIN_PASSWORD=ChangeMe!2026

# ==== Optional: Chatbot ====
ANTHROPIC_API_KEY=sk-ant-...

# ==== Optional: Real-time admin notifications ====
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=us2
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=us2

# ==== Optional: Notification channels ====
# Configure ANY ONE (or all) — they all fire independently when a contact form is submitted.

# (1) WhatsApp via CallMeBot — free but can be flaky
WHATSAPP_PHONE=
CALLMEBOT_API_KEY=

# (2) Telegram bot — free, unlimited, MOST RELIABLE
# Setup:
#   1. Telegram → search "BotFather" → /newbot → name your bot → copy TOKEN
#   2. Telegram → search "userinfobot" → /start → copy your CHAT_ID
#   3. Send /start to your new bot once (so it can DM you)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# (3) Email via Resend — free 100/day
# Setup:
#   1. Sign up at https://resend.com
#   2. API Keys → Create → copy
#   3. RESEND_FROM = "onboarding@resend.dev" for testing (no domain setup needed)
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
RESEND_TO=your-email@gmail.com
