# Copy this file to .env.local and fill in real values.
# In Vercel, add the same vars under Settings -> Environment Variables.

# ==== Required ====
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/nextgen?retryWrites=true&w=majority
NEXTAUTH_SECRET=replace-with-long-random-string
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@nextgendigitalhub.com
ADMIN_PASSWORD=ChangeMe!2026

# ==== Optional ====
# Anthropic Claude API for chatbot
ANTHROPIC_API_KEY=sk-ant-...

# Pusher for real-time admin notifications (free tier)
# https://dashboard.pusher.com
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=us2
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=us2

# WhatsApp notifications via CallMeBot (free)
# Setup:
#   1. Save +34 644 51 95 23 in your WhatsApp contacts
#   2. Send "I allow callmebot to send me messages"
#   3. You'll receive your API key in reply
# WHATSAPP_PHONE format: digits only with country code (e.g. 923211464482)
WHATSAPP_PHONE=
CALLMEBOT_API_KEY=
